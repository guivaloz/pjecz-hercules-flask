{% extends 'layouts/app.jinja2' %}
{% import 'macros/list.jinja2' as list %}
{% import 'macros/topbar.jinja2' as topbar %}

{% block title %}{{ titulo }}{% endblock %}

{% block topbar_actions %}
    {% call topbar.page_buttons(titulo) %}
        {% if current_user.can_view('PEN AGENTES MP') %}
            {{ topbar.button('Agentes MP', url_for('pen_agentes_mp.list_active'),'mdi:account-circle') }}
        {% endif %}
        {% if current_user.can_view('PEN EXPEDIENTES') %}
            {{ topbar.button('Expedientes', url_for('pen_expedientes.list_active'),'mdi:folder') }}
        {% endif %}
        {% if current_user.can_view('PEN JUECES') %}
            {{ topbar.button('Jueces', url_for('pen_jueces.list_active'),'mdi:account-circle') }}
        {% endif %}
        {% if current_user.can_view('PEN SECRETARIOS') %}
            {{ topbar.button('Secretarios', url_for('pen_secretarios.list_active'),'mdi:account-circle') }}
        {% endif %}
        {% if current_user.can_admin('PEN INCULPADOS') %}
            {% if estatus == 'A' %}{{ topbar.button_list_inactive('Inactivos', url_for('pen_inculpados.list_inactive')) }}{% endif %}
            {% if estatus == 'B' %}{{ topbar.button_list_active('Activos', url_for('pen_inculpados.list_active')) }}{% endif %}
        {% endif %}
        {# if current_user.can_insert('PEN INCULPADOS') %}
            {{ topbar.button_new('Nuevo Inculpado', url_for('pen_inculpados.new')) }}
        {% endif #}
    {% endcall %}
{% endblock %}

{% block content %}
    {% call list.card() %}
        <!-- Filtros pen_inculpados -->
        <div class="row">
            <div class="col">
                <form class="row g-1 mb-3" id="filtradorForm" onsubmit="filtrosPenInculpados.buscar(); return false;">
                    <div class="col-4">
                        <div class="form-floating">
                            <input id="filtroNombres" type="text" class="form-control" aria-label="Nombres" style="text-transform: uppercase;">
                            <label for="filtroNombres">Nombres</label>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="form-floating">
                            <input id="filtroApellidoPaterno" type="text" class="form-control" aria-label="Apellido paterno" style="text-transform: uppercase;">
                            <label for="filtroApellidoPaterno">Apellido paterno</label>
                        </div>
                    </div>
                    <div class="col-4 text-end">
                        <button title="Buscar" class="btn btn-primary btn-lg" onclick="filtrosPenInculpados.buscar(); return false;" id="button-buscar"><span class="iconify" data-icon="mdi:magnify"></span></button>
                        <button title="Limpiar" class="btn btn-warning btn-lg" type="reset" onclick="filtrosPenInculpados.limpiar();" id="button-limpiar"><span class="iconify" data-icon="mdi:broom"></span></button>
                    </div>
                </form>
            </div>
        </div>
        <!-- DataTable pen_inculpados -->
        <table id="pen_inculpados_datatable" class="table {% if estatus == 'B'%}table-dark{% endif %} display nowrap" style="width:100%">
            <thead>
                <tr>
                    <th>Expediente</th>
                    <th>Nombres</th>
                    <th>Apellido_paterno</th>
                    <th>Apellido_materno</th>
                    <th>Apodo</th>
                    <th>Sexo</th>
                    <th>Status</th>
                </tr>
            </thead>
        </table>
    {% endcall %}
{% endblock %}

{% block custom_javascript %}
    <script src="/static/js/datatables-constructor.js"></script>
    <script src="/static/js/datatables-filtros.js"></script>
    <script>
        // DataTable pen_inculpados
        const constructorDataTable = new ConfigDataTable( '{{ csrf_token() }}' );
        let configDataTable = constructorDataTable.config();
        configDataTable['ajax']['url'] = '/pen_inculpados/datatable_json';
        configDataTable['ajax']['data'] = {{ filtros }};
        configDataTable['columns'] = [
            { data: 'expediente' },
            { data: 'detalle' },
            { data: 'apellido_paterno' },
            { data: 'apellido_materno' },
            { data: 'apodo' },
            { data: 'sexo' },
            { data: 'estado' }
        ];
        configDataTable['columnDefs'] = [
            {
                targets: 1, // detalle
                data: null,
                render: function(data, type, row, meta) {
                    return '<a href="' + data.url + '">' + data.clave + '</a>';
                }
            }
        ];
        // Filtros pen_inculpados
        const filtrosPenInculpados = new FiltrosDataTable('#pen_inculpados_datatable', configDataTable);
        filtrosPenInculpados.agregarInput('filtroNombres', 'nombres');
        filtrosPenInculpados.agregarInput('filtroApellidoPaterno', 'apelido_paterno');
        filtrosPenInculpados.agregarInput('filtroApellidoMaterno', 'apelido_materno');
        filtrosPenInculpados.precargar();
    </script>
{% endblock %}
